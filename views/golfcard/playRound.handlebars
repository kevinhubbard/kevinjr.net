<script>
const socket = io();
const roundID = {{roundID}};
const userID = "{{userId}}";
const participants = {{{json players}}};
const courseInfo = {{{json currentRound}}};
const holes = {{{json holes}}};

socket.on('connect', () => {
	socket.emit('joinRoom', `round-${roundID}`);
	refreshScores(roundID);
});

document.addEventListener("visibilitychange", () => {
	if (!document.hidden) {
		refreshScores(roundID);
	}
});

document.addEventListener('DOMContentLoaded', () => {
	let par = 0;
	let holeNum = 1;
	let holeStrokes = 0;
	let score = 0;

	for (let i = 0; i < holes.length; i++) {
		par += holes[i].par;
	}

	document.getElementById('courseName').textContent = courseInfo.Course.courseName;
	document.getElementById('coursePar').textContent = `Par: ${par}`;
	document.getElementById('courseYards').textContent = `Yards: ${courseInfo.Teebox.totalYards}  (${courseInfo.Teebox.teeName} tees)`;
	document.getElementById('slopeRating').textContent = `Slope: ${courseInfo.Teebox.slope} Rating: ${courseInfo.Teebox.rating}`;

	participants.forEach(golfer => {
		const div = document.createElement('div');
		div.id = `scoreboard-${golfer.userID}`;
		div.className = 'scoreboard';

		div.innerHTML = `
			<h2>${golfer.User.name}</h2>
			<div class="total-score">0</div>
			<div class="hole-details hidden"></div>
		`;

		document.getElementById('scoreboards').appendChild(div);
	});

	if (participants.some(p => p.userID === userID)) {
  		const inputDiv = document.getElementById('playerInputArea');
 		inputDiv.innerHTML = `
 		<input type="checkbox" id="fir" class="check" name="fir">
 		<label for="fir">Fairway in Regulation</label><br>
 		<input type="checkbox" id="gir" class="check" name="gir">
 		<label for="gir">Green in Regulation</label><br>
		<button id="add-stroke">Add Stroke</button>
		<button id="finish-hole" disabled>Finish Hole</button>`;



	 	// Display first hole info
		document.getElementById('current-hole').textContent = `Hole: ${holeNum}`;
		document.getElementById('holePar').textContent = `Par: ${holes[holeNum - 1].par}`;
		document.getElementById('holeYards').textContent = `Yards: ${holes[holeNum - 1].yards}`;

		// Add stroke listener
		document.getElementById('add-stroke').addEventListener('click', () => {
			holeStrokes++;
			document.getElementById('current-strokes').textContent = holeStrokes;
			document.getElementById('finish-hole').disabled = false;
		});

		// Finish hole listener
		document.getElementById('finish-hole').addEventListener('click', () => {
			socket.emit('holeFinished', {
				roundID,
			  	userID,
			  	holeNumber: holeNum,
			  	strokes: holeStrokes,
			  	fairwayHit: document.getElementById('fir').checked,
			  	greenInReg: document.getElementById('gir').checked
			});
			// Reset UI for next hole
			holeNum++;
			holeStrokes = 0;
			document.getElementById('current-strokes').textContent = 0;
			document.getElementById('finish-hole').disabled = true;

			// Update hole info
			if (holeNum <= 18) {
				document.getElementById('current-hole').textContent = `Hole: ${holeNum}`;
			  	document.getElementById('holePar').textContent = `Par: ${holes[holeNum - 1].par}`;
			  	document.getElementById('holeYards').textContent = `Yards: ${holes[holeNum - 1].yards}`;
				document.querySelectorAll('input[type="checkbox"]').forEach(cb => {
			  		cb.checked = false;
			  	});
			} else {
				document.getElementById('add-stroke').disabled = true;
				//alert('Round over do you want to save?');
			}
		});
	}
	socket.on('updatedScore', ({ roundID }) => {
		console.log('received update');
		refreshScores(roundID);
	});
});

async function refreshScores(roundID) {
	const res = await fetch(`/golfcard/rounds/${roundID}/scores`);
	const scores = await res.json();

	renderScoreboard(scores);
}

function renderScoreboard(scores) {
	window.latestScores = scores;
	const totals = {};

	scores.forEach(score => {
		if (!totals[score.userID]) {
			totals[score.userID] = 0;
		}
		totals[score.userID] += score.strokes;
	});

	// update ui
	Object.keys(totals).forEach(userID => {
		const div = document.getElementById(`scoreboard-${userID}`);
		if (!div) return;

		const totalEl = div.querySelector('.total-score');
		if (totalEl) {
			totalEl.textContent = totals[userID];
		}
	});
}

document.addEventListener('click', (e) => {
	const scoreboard = e.target.closest('[id^="scoreboard-"]');
	if (!scoreboard) return;

	const userID = scoreboard.id.replace('scoreboard-', '');
	const detailDiv = scoreboard.querySelector('.hole-details');

	if (detailDiv.classList.contains('hidden')) {
		const userScores = window.latestScores.filter(s => s.userID === userID);
		detailDiv.innerHTML = userScores.map(s => 
		`<div>Hole ${s.holeNumber}: ${s.strokes}</div>`).join('');

		detailDiv.classList.remove('hidden');
	} else {
		detailDiv.classList.add('hidden');
	}
});


</script>

<div id="mainApp">
	<div id="ci">
		<h1 id="courseName"></h1>
		<p id="coursePar"></p>
		<p id="courseYards"></p>
		<p id="slopeRating"></p>
	</div>
	<div id="app">
		<div id="holeDetails">
			<p id="info">
				<span id="current-hole" class="holeAttribute"></span>
				<span id="holePar" class="holeAttribute"></span>
				<span id="holeYards" class="holeAttribute"></span>
			</p>
			<p>Strokes: <span id="current-strokes">0</span></p>
			<p>Score: <span id="usrScore"></span></p>
		</div>
		<div id="playerInputArea"></div>
	</div>
	<div id="scoreboards"></div>
</div>